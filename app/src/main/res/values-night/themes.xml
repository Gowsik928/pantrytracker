<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.FreshnessTracker" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/surface_white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_red</item>
        <item name="colorSecondaryVariant">@color/accent_red</item>
        <item name="colorOnSecondary">@color/surface_white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="Theme.FreshnessTracker" parent="Base.Theme.FreshnessTracker" />
</resources>